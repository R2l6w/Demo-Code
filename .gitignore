<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>بطاقة الولاء - مقهى السعادة</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f9f6f0; /* لون كريمي يناسب المقاهي */
            text-align: center;
            margin: 0;
            padding: 20px;
            color: #3e2723;
        }
        .container {
            max-width: 400px;
            margin: auto;
            background: #fff;
            padding: 30px 20px;
            border-radius: 15px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        h1 { font-size: 24px; margin-bottom: 5px; }
        p { font-size: 14px; color: #795548; margin-bottom: 25px; }
        
        .stamps-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 30px;
        }
        .stamp-box {
            width: 80px;
            height: 80px;
            margin: auto;
            border: 2px dashed #d7ccc8;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            background-color: #fafafa;
            transition: 0.3s;
        }
        .stamp-box.active {
            background-color: #795548;
            color: white;
            border: 2px solid #3e2723;
        }
        
        .btn-admin {
            background-color: #3e2723;
            color: #fff;
            border: none;
            padding: 12px 25px;
            border-radius: 8px;
            font-size: 16px;
            cursor: pointer;
            width: 100%;
        }
        .btn-admin:hover { background-color: #5d4037; }
    </style>
</head>
<body>

    <div class="container">
        <!-- يمكنك استبدال النص بصورة شعار المقهى -->
        <h1>☕ مقهى السعادة</h1>
        <p>اجمع 5 أختام واحصل على قهوتك السادسة مجاناً!</p>

        <div class="stamps-grid" id="stampsGrid">
            <!-- سيتم توليد الأختام هنا بواسطة الجافاسكربت -->
        </div>

        <button class="btn-admin" onclick="addStamp()">إضافة ختم (للموظف فقط)</button>
    </div>

    <script>
        const totalStamps = 6;
        let currentStamps = localStorage.getItem('demo_stamps') ? parseInt(localStorage.getItem('demo_stamps')) : 0;
        const secretCode = "0000"; // الرمز السري للنسخة التجريبية

        function renderStamps() {
            const grid = document.getElementById('stampsGrid');
            grid.innerHTML = '';
            for (let i = 1; i <= totalStamps; i++) {
                const box = document.createElement('div');
                box.className = 'stamp-box ' + (i <= currentStamps ? 'active' : '');
                
                if (i <= currentStamps) {
                    box.innerHTML = '☕'; // شكل الختم
                } else if (i === totalStamps) {
                    box.innerHTML = '🎁'; // شكل الجائزة
                }
                
                grid.appendChild(box);
            }
        }

        function addStamp() {
            if (currentStamps >= totalStamps) {
                alert("تهانينا! بطاقتك مكتملة. تفضل هديتك المجانية.");
                if(confirm("هل تريد تصفير البطاقة للبدء من جديد؟")) {
                    currentStamps = 0;
                    localStorage.setItem('demo_stamps', currentStamps);
                    renderStamps();
                }
                return;
            }

            const codeInput = prompt("الرجاء إدخال الرمز السري للموظف:");
            if (codeInput === secretCode) {
                currentStamps++;
                localStorage.setItem('demo_stamps', currentStamps);
                renderStamps();
                
                if (currentStamps === totalStamps) {
                    setTimeout(() => alert("اكتملت البطاقة! يستحق العميل الجائزة الآن."), 300);
                }
            } else if (codeInput !== null) {
                alert("الرمز السري غير صحيح!");
            }
        }

        // تشغيل الواجهة عند فتح الموقع
        renderStamps();
    </script>
</body>
</html>
